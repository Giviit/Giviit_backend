PORT=5000
NODE_ENV=development

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

JWT_SECRET=

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

SHUFTI_CLIENT_ID=
SHUFTI_SECRET_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

EMAIL_FROM=noreply@giviit.ng
ADMIN_EMAIL=admin@giviit.ng
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=

# Optional: send emails via a Google Apps Script web app instead of SMTP
# (free Gmail-based sending, useful for testing). See Backend/google-apps-script/EmailSender.gs
APPS_SCRIPT_EMAIL_URL=
APPS_SCRIPT_EMAIL_SECRET=

# Optional second Gmail account, used for trust/fraud-related emails only
# (campaignFraudulent, campaignFlaggedForReview, accountBanned, banAppeal*).
# Falls back to the account above if unset. See EmailSender2.gs
APPS_SCRIPT_EMAIL_URL_2=
APPS_SCRIPT_EMAIL_SECRET_2=

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
